# Copy to .env and adjust for your environment.

# Postgres in production/docker-compose:
#   DATABASE_URL=postgresql+psycopg2://hifzai:hifzai@db:5432/hifzai
# SQLite for zero-setup local dev (no server to install):
#   DATABASE_URL=sqlite:///./hifzai.db
DATABASE_URL=postgresql+psycopg2://hifzai:hifzai@localhost:5432/hifzai

# Generate a real secret for anything beyond local dev:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
# Phase 17: shortened from 24h now that refresh tokens exist (see below) —
# a leaked access token is only useful for this long, not a full day.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173

# Where uploaded practice-attempt audio is stored on disk
MEDIA_ROOT=./media

# Phase 17 — account lockout after repeated failed logins.
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# Phase 17 — password reset links point back at the frontend:
# {FRONTEND_URL}/reset-password?token=...
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Phase 14 — recitation analysis (optional). Without this set, the
# "Analyze recitation" action returns a clear error instead of running;
# nothing else in the app is affected. Get a key at platform.openai.com —
# this calls the Whisper transcription API and costs money per request,
# it isn't free/unlimited.
OPENAI_API_KEY=
# Phase 24 — the AI assistant reuses the key above; this just picks which
# chat-completions model it calls.
ASSISTANT_CHAT_MODEL=gpt-4o-mini

# Phase 16 — Web Push (optional). Generate a VAPID keypair with:
#   python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print(v.private_pem().decode())"
# or any VAPID key generator; without these set, push sends are silently
# skipped and in-app notifications still work normally.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@example.com

# Phase 16 — SMTP for the weekly parent email digest (optional). Without
# SMTP_HOST set, the email step is skipped (logged, not raised) — the
# in-app notification is still created either way.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=hifzai@example.com
